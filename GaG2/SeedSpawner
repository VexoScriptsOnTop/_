-- helper to get seed data
local function getSeedData(seedName)
	for _, data in ipairs(seedModule) do
		if data.SeedName == seedName then
			return data
		end
	end
	return nil
end

-- helper to get seed image id
local function getSeedImageId(seedName)
	local stringValue = seedPics:FindFirstChild(seedName)
	if stringValue and stringValue:IsA("StringValue") then
		return stringValue.Value
	end
	return "rbxassetid://0"
end

